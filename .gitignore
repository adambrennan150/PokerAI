# Poker McPokerface — git ignore rules

# --- Python -----------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# --- Virtual environments ---------------------------------------------
.venv/
venv/
env/

# --- Jupyter ----------------------------------------------------------
.ipynb_checkpoints/

# --- Session logs (regenerated by running tournaments) ----------------
# These can grow large quickly — every tournament produces .jsonl files.
# If you want to share a specific session, copy it out or commit it
# explicitly with `git add -f runs/<session_id>/`.
runs/

# --- IDE / editor metadata --------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS metadata ------------------------------------------------------
.DS_Store
Thumbs.db

# --- Secrets — never commit these -------------------------------------
.env
*.key
secrets/
